generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum IdeaStatus {
  RAW
  TRIAGED
  IN_FACTORY
  PLAN_READY
  REVIEW_PENDING
  APPROVED
  NEEDS_REVISION
  TASKED
  IN_PRODUCTION
  ASSET_READY
  PUBLISHED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Potential {
  UNKNOWN
  SMALL
  MEDIUM
  LARGE
  MASSIVE
}

model Idea {
  id        String        @id @default(cuid())
  title     String
  rawText   String
  summary   String?
  category  String        @default("Uncategorized")
  tags      String        @default("")
  status    IdeaStatus    @default(RAW)
  priority  Priority      @default(MEDIUM)
  potential Potential     @default(UNKNOWN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  plans     FactoryPlan[]
}

model Run {
  id                String             @id
  goal              String
  mode              String             @default("observer")
  status            String             @default("approval_pending")
  planHash          String
  stateHash         String
  staleReason       String             @default("")
  stopReason        String             @default("none")
  duplicateOf       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  approvals         Approval[]
  events            ExecutionEvent[]
  locks             ExecutionLock[]
  rollbackSnapshots RollbackSnapshot[]

  @@index([createdAt])
  @@index([status])
  @@index([planHash, stateHash])
}

model Approval {
  id         String    @id @default(cuid())
  runId      String
  taskId     String
  token      String    @unique
  status     String    @default("pending")
  decision   String    @default("")
  reason     String    @default("")
  expiresAt  DateTime
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  run        Run       @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([status])
  @@index([expiresAt])
}

model ExecutionEvent {
  id        String   @id @default(cuid())
  runId     String
  taskId    String?
  event     String
  message   String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([event])
  @@index([createdAt])
}

model ExecutionLock {
  id         String    @id @default(cuid())
  lockKey    String    @unique
  runId      String?
  owner      String
  status     String    @default("active")
  acquiredAt DateTime  @default(now())
  expiresAt  DateTime
  releasedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  run        Run?      @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([status])
  @@index([expiresAt])
}

model RollbackSnapshot {
  id               String    @id @default(cuid())
  runId            String
  taskId           String?
  kind             String
  targetId         String?
  targetPath       String?
  content          String
  metadata         String    @default("{}")
  restoreReference String
  restoredAt       DateTime?
  createdAt        DateTime  @default(now())
  run              Run       @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([kind])
  @@index([targetId])
  @@index([targetPath])
}

model ExecutionRequest {
  id                 String    @id @default(cuid())
  taskId             String    @map("task_id")
  actionType         String    @map("action_type")
  payload            String
  status             String    @default("pending")
  approvalStatus     String    @default("approved") @map("approval_status")
  rollbackSnapshotId String?   @map("rollback_snapshot_id")
  rollbackPayload    String    @default("") @map("rollback_payload")
  executionHash      String    @unique @map("execution_hash")
  workerId           String?   @map("worker_id")
  retryCount         Int       @default(0) @map("retry_count")
  maxRetries         Int       @default(2) @map("max_retries")
  result             String    @default("")
  error              String    @default("")
  auditLog           String    @default("[]") @map("audit_log")
  claimedAt          DateTime? @map("claimed_at")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([approvalStatus])
  @@index([workerId])
  @@index([createdAt])
  @@map("execution_requests")
}

model ExecutionWorker {
  id                  String    @id
  actionType          String    @map("action_type")
  status              String    @default("idle")
  healthState         String    @default("healthy") @map("health_state")
  lastHeartbeatAt     DateTime  @default(now()) @map("last_heartbeat_at")
  currentRequestId    String?   @map("current_request_id")
  processedCount      Int       @default(0) @map("processed_count")
  failedCount         Int       @default(0) @map("failed_count")
  staleRecoveredCount Int       @default(0) @map("stale_recovered_count")
  shutdownRequested   Boolean   @default(false) @map("shutdown_requested")
  startedAt           DateTime  @default(now()) @map("started_at")
  stoppedAt           DateTime? @map("stopped_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([actionType])
  @@index([status])
  @@index([healthState])
  @@index([lastHeartbeatAt])
  @@map("execution_workers")
}

model FactoryPlan {
  id             String   @id @default(cuid())
  ideaId         String
  title          String
  summary        String
  concept        String
  requiredAssets String
  risks          String
  nextActions    String
  status         String   @default("REVIEW_PENDING")
  revisionNotes  String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  idea           Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tasks          Task[]
}

model ActivityEvent {
  id         String   @id @default(cuid())
  eventType  String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([entityType])
  @@index([createdAt])
}

model Task {
  id          String        @id @default(cuid())
  planId      String
  title       String
  description String
  status      String        @default("TODO")
  priority    Priority      @default(MEDIUM)
  labels      String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  plan        FactoryPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  blockers    TaskBlocker[] @relation("TaskBlockers")
  blocking    TaskBlocker[] @relation("TaskBlocking")
}

model TaskBlocker {
  id            String   @id @default(cuid())
  taskId        String
  blockerTaskId String
  createdAt     DateTime @default(now())
  task          Task     @relation("TaskBlockers", fields: [taskId], references: [id], onDelete: Cascade)
  blockerTask   Task     @relation("TaskBlocking", fields: [blockerTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, blockerTaskId])
  @@index([blockerTaskId])
}
