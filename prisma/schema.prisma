generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum IdeaStatus {
  RAW
  TRIAGED
  IN_FACTORY
  PLAN_READY
  REVIEW_PENDING
  APPROVED
  NEEDS_REVISION
  TASKED
  IN_PRODUCTION
  ASSET_READY
  PUBLISHED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Potential {
  UNKNOWN
  SMALL
  MEDIUM
  LARGE
  MASSIVE
}

model Idea {
  id        String        @id @default(cuid())
  title     String
  rawText   String
  summary   String?
  category  String        @default("Uncategorized")
  tags      String        @default("")
  status    IdeaStatus    @default(RAW)
  priority  Priority      @default(MEDIUM)
  potential Potential     @default(UNKNOWN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  plans     FactoryPlan[]
}

model FactoryPlan {
  id             String   @id @default(cuid())
  ideaId         String
  title          String
  summary        String
  concept        String
  requiredAssets String
  risks          String
  nextActions    String
  status         String   @default("REVIEW_PENDING")
  revisionNotes  String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  idea           Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tasks          Task[]
}

model Task {
  id          String        @id @default(cuid())
  planId      String
  title       String
  description String
  status      String        @default("TODO")
  priority    Priority      @default(MEDIUM)
  labels      String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  plan        FactoryPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  blockers    TaskBlocker[] @relation("TaskBlockers")
  blocking    TaskBlocker[] @relation("TaskBlocking")
}

model TaskBlocker {
  id            String   @id @default(cuid())
  taskId        String
  blockerTaskId String
  createdAt     DateTime @default(now())
  task          Task     @relation("TaskBlockers", fields: [taskId], references: [id], onDelete: Cascade)
  blockerTask   Task     @relation("TaskBlocking", fields: [blockerTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, blockerTaskId])
  @@index([blockerTaskId])
}
